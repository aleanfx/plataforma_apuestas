# URL del backend BetmarPlay. En dev apunta al server local; en producción, a Render.
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# Client ID de Google para "Iniciar sesión con Google" (lo creas en Google Cloud
# Console). Es público (va al navegador). Sin él, el botón muestra "pronto".
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
