# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas .env al repositorio (está en .gitignore).

# Conexión a PostgreSQL (Neon).
# DATABASE_URL = conexión POOLED (host con "-pooler"), la usa la app en runtime.
# DIRECT_URL  = conexión DIRECTA (host sin "-pooler"), la usan las migraciones de Prisma.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler/DB?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Secretos JWT (genera cadenas largas y aleatorias distintas para cada uno).
JWT_ACCESS_SECRET="cambia-esto-por-una-cadena-larga-aleatoria"
JWT_REFRESH_SECRET="cambia-esto-por-otra-cadena-larga-aleatoria"

# Email del usuario que tendrá rol admin (aprueba depósitos/retiros).
ADMIN_EMAIL="betmarplay@gmail.com"

# Orígenes permitidos para CORS (separados por coma). En dev: el front local.
CORS_ORIGINS="http://localhost:3000"

# Puerto del servidor (en dev 4000; en Render lo inyecta la plataforma).
PORT="4000"

# Tasa Bs/USD por defecto (se puede mover a DB luego).
BS_PER_USD="40"
